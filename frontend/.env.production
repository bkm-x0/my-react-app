# Production - Update these with your actual backend URL
# Example: If you deploy backend on Render, it would be something like:
# REACT_APP_API_URL=https://your-backend.onrender.com/api
# REACT_APP_API_HOST=https://your-backend.onrender.com

REACT_APP_API_URL=https://YOUR_BACKEND_URL/api
REACT_APP_API_HOST=https://YOUR_BACKEND_URL

# Disable react-refresh in production (fixes Render build error)
FAST_REFRESH=false
GENERATE_SOURCEMAP=false
CI=false
DISABLE_ESLINT_PLUGIN=true
